# Copy to .env and fill in the values we provided.
#   cp env.example .env

# LLM provider — bring your own key.
# Recommended: the OpenAI Agents SDK (the starter scaffold uses it).
OPENAI_API_KEY=
# Silences a harmless tracing 403 from the OpenAI Agents SDK. Leave as-is if using OpenAI.
OPENAI_AGENTS_DISABLE_TRACING=1
# ...or use Google's Agent Development Kit (ADK) instead — set this and adapt the scaffold.
GOOGLE_API_KEY=

# Avis API. Base URL is set below.
# Grab your AVIS_API_KEY here: https://share.1password.com/s#yaM3mKXX9P8_BHxWxpaSzhqqe4YIq4p6AaUafkLJ9vY
AVIS_API_KEY=
AVIS_API_URL=https://avis-mock-api-production.up.railway.app
